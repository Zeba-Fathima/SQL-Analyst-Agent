# Copy this file to ".env" and fill in your key.

# --- Google Gemini (default, has a free tier) ---
GOOGLE_API_KEY=
LLM_MODEL=google_genai:gemini-2.0-flash

# --- To use a different provider instead, set LLM_MODEL and the matching key ---
# Anthropic:  LLM_MODEL=anthropic:claude-sonnet-4-5   +  ANTHROPIC_API_KEY=...
# OpenAI:     LLM_MODEL=openai:gpt-4o-mini            +  OPENAI_API_KEY=...
# (install the matching package: langchain-anthropic / langchain-openai)
